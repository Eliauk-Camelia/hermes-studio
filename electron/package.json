{
  "name": "camelia-studio",
  "version": "0.0.5",
  "description": "Camelia Studio — AI 编程助手",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.camelia.studio",
    "productName": "Camelia Studio",
    "directories": {
      "output": "../dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "../src/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "../src/static/icon.svg",
      "category": "Development"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "../src/static/icon.svg"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "../src/static/icon.svg"
    },
    "publish": {
      "provider": "github",
      "owner": "Eliauk-Camelia",
      "repo": "camelia-studio"
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9"
  },
  "allowScripts": {
    "electron@35.7.5": true
  }
}
